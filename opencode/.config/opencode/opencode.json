{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "mv *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "npm install -g *": "ask",
      "brew *": "ask",
      "cargo install *": "ask"
    }
  }
}
