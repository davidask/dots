// Parallel Productivity Workflow
// Layout for Worktree Parallel Productivity
// Top: Editor (75%) | OpenCode (25%)
// Bottom: Terminal (25%)
layout {
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar"
    }
    pane split_direction="horizontal" {
        pane split_direction="vertical" {
            pane edit="."
            pane command="opencode" size="35%" focus=true
        }
        pane size="25%"
    }
    pane size=1 borderless=true {
        plugin location="zellij:status-bar"
    }
}
