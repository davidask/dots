<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.davidask.sync-appearance</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/davidask/.dotfiles/bin/sync-appearance-daemon</string>
